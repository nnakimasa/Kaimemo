{
  "name": "kaimemo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.1.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@kaimemo/web",
    "dev:api": "turbo run dev --filter=@kaimemo/api",
    "dev:mobile": "turbo run dev --filter=@kaimemo/mobile",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @kaimemo/api exec -- prisma generate",
    "db:migrate": "pnpm --filter @kaimemo/api exec -- prisma migrate dev",
    "db:studio": "pnpm --filter @kaimemo/api exec -- prisma studio",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^18.3.0",
      "@types/react-dom": "^18.3.0"
    }
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
