{
    "permissions": {
      "defaultMode": "acceptEdits",
      "allow": [
        "Edit",
        "MultiEdit",
        "Read",
        "Glob",
        "Grep",
        "Bash(npm run:*)"
      ],
      "deny": [
        "Bash(git status:*)",
        "Bash(git diff:*)",
        "Bash(git log:*)",
        "Bash(rm -rf:*)",
        "Bash(sudo:*)"
      ]
    }
  }