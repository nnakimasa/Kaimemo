generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String             @id @default(uuid())
  email                 String             @unique
  displayName           String             @map("display_name")
  avatarUrl             String?            @map("avatar_url")
  cognitoId             String             @unique @map("cognito_id")
  planType              String             @default("free") @map("plan_type")
  subscriptionStatus    String             @default("none") @map("subscription_status")
  stripeCustomerId      String?            @map("stripe_customer_id")
  subscriptionStartedAt DateTime?          @map("subscription_started_at")
  subscriptionExpiresAt DateTime?          @map("subscription_expires_at")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  // Relations
  ownedLists            List[]             @relation("ListOwner")
  ownedGroups           Group[]            @relation("GroupOwner")
  groupMemberships      GroupMember[]
  assignedItems         Item[]             @relation("ItemAssignee")
  checkedItems          Item[]             @relation("ItemChecker")
  shareTokensCreated    ListShareToken[]
  recurringLists        RecurringList[]

  @@map("users")
}

model List {
  id          String   @id @default(uuid())
  name        String
  description String?
  ownerId     String   @map("owner_id")
  groupId     String?  @map("group_id")
  isArchived  Boolean   @default(false) @map("is_archived")
  sortOrder   Int       @default(0) @map("sort_order")
  reminderAt  DateTime? @map("reminder_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  owner       User              @relation("ListOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  group       Group?            @relation(fields: [groupId], references: [id], onDelete: SetNull)
  items       Item[]
  shareTokens ListShareToken[]

  @@index([ownerId])
  @@index([groupId])
  @@map("lists")
}

model RecurringList {
  id              String          @id @default(uuid())
  name            String
  ownerId         String          @map("owner_id")
  groupId         String?         @map("group_id")
  sortOrder       Int             @default(0) @map("sort_order")
  // Schedule
  frequency       String          @default("weekly")   // weekly | biweekly | monthly
  weekday         Int             @default(5)           // 0=Mon...6=Sun
  monthlyWeek     Int             @default(1) @map("monthly_week")  // 1-5
  daysBefore      Int             @default(2) @map("days_before")   // 1-30 or 0=1mo
  reminderTime    String?         @map("reminder_time")             // "09:00" or null
  isActive        Boolean         @default(true) @map("is_active")
  nextGenerationAt DateTime?      @map("next_generation_at")
  lastGeneratedAt  DateTime?      @map("last_generated_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  owner           User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  group           Group?          @relation(fields: [groupId], references: [id], onDelete: SetNull)
  items           RecurringItem[]

  @@index([ownerId])
  @@index([nextGenerationAt])
  @@map("recurring_lists")
}

model RecurringItem {
  id              String        @id @default(uuid())
  recurringListId String        @map("recurring_list_id")
  name            String
  quantity        Int           @default(1)
  unit            String?
  sortOrder       Int           @default(0) @map("sort_order")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  recurringList   RecurringList @relation(fields: [recurringListId], references: [id], onDelete: Cascade)

  @@index([recurringListId])
  @@map("recurring_items")
}

model ListShareToken {
  id        String    @id @default(uuid())
  listId    String    @map("list_id")
  token     String    @unique
  createdBy String    @map("created_by")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  // Relations
  list      List      @relation(fields: [listId], references: [id], onDelete: Cascade)
  creator   User      @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([listId])
  @@map("list_share_tokens")
}

model Item {
  id          String    @id @default(uuid())
  listId      String    @map("list_id")
  name        String
  quantity    Int       @default(1)
  unit        String?
  note        String?
  isChecked   Boolean   @default(false) @map("is_checked")
  checkedAt   DateTime? @map("checked_at")
  checkedBy   String?   @map("checked_by")
  assigneeId  String?   @map("assignee_id")
  priority    String    @default("medium")
  sortOrder   Int       @default(0) @map("sort_order")
  category    String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  list        List      @relation(fields: [listId], references: [id], onDelete: Cascade)
  assignee    User?     @relation("ItemAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  checker     User?     @relation("ItemChecker", fields: [checkedBy], references: [id], onDelete: SetNull)

  @@index([listId])
  @@index([assigneeId])
  @@map("items")
}

model Group {
  id              String        @id @default(uuid())
  name            String
  description     String?
  ownerId         String        @map("owner_id")
  inviteCode      String?       @unique @map("invite_code")
  inviteExpiresAt DateTime?     @map("invite_expires_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Relations
  owner           User          @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members         GroupMember[]
  lists           List[]
  recurringLists  RecurringList[]

  @@index([ownerId])
  @@map("groups")
}

model GroupMember {
  id        String   @id @default(uuid())
  groupId   String   @map("group_id")
  userId    String   @map("user_id")
  role      String   @default("viewer")
  joinedAt  DateTime @default(now()) @map("joined_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
  @@map("group_members")
}
